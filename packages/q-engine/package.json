{
  "name": "@qpad/engine",
  "version": "0.1.0",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "dependencies": {
    "@qpad/core": "0.1.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:parser": "peggy --format es --dts -o src/q-parser.ts src/q.peggy && node scripts/stamp-parser-nocheck.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "pretest": "npm run build:parser",
    "test": "npx vitest run"
  },
  "devDependencies": {
    "peggy": "^5.1.0",
    "vitest": "^4.1.4"
  }
}
