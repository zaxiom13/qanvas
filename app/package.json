{
  "name": "@qanvas/app",
  "version": "0.1.0",
  "private": true,
  "description": "Qanvas frontend: Svelte + Vite + Monaco + jqport with pluggable q runtime backends",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 4173",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1 --port 4173",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "test:browser": "playwright test",
    "mobile:sync": "npm run build && cap sync",
    "mobile:ios": "npm run mobile:sync && cap open ios",
    "mobile:android": "npm run mobile:sync && cap open android"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/cli": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "@capacitor/ios": "^8.3.1",
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.1",
    "@lezer/highlight": "^1.2.3",
    "@qpad/core": "*",
    "@qpad/engine": "*",
    "@qpad/language": "*",
    "@simonwep/pickr": "^1.9.1",
    "gifenc": "^1.0.3",
    "monaco-editor": "^0.52.2",
    "nouislider": "^15.8.1",
    "svelte": "^5.38.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "@tailwindcss/vite": "^4.1.13",
    "@types/node": "^24.3.0",
    "svelte-check": "^4.3.1",
    "tailwindcss": "^4.1.13",
    "typescript": "^5.9.2",
    "vite": "^7.1.5",
    "vitest": "^4.1.4"
  }
}
